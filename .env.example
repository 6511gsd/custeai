# ============================================================
# CusteAi - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no Git!
# ============================================================

# Ambiente
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Banco de dados (PostgreSQL / Supabase) ────────────────
#
# SUPABASE (recomendado para produção):
#   1. Acesse: https://supabase.com/dashboard → seu projeto
#   2. Vá em: Project Settings → Database → Connection string → URI
#   3. Cole a URI abaixo (substitua [YOUR-PASSWORD])
#
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Alternativa: PostgreSQL local
# DATABASE_URL=postgresql://postgres:senha@localhost:5432/custeai

# Campos individuais (use DATABASE_URL OU os campos abaixo, não os dois)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=custeai
# DB_USER=postgres
# DB_PASSWORD=sua_senha_aqui
# DB_SSL=false

# ── Supabase (opcional - apenas se usar Storage ou Auth do Supabase) ──
# SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   ← NUNCA exponha no frontend!

# ── JWT / Sessões ─────────────────────────────────────────
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_PARA_UMA_STRING_LONGA_E_ALEATORIA_AQUI
JWT_EXPIRES=15m
REFRESH_EXPIRES=30d

# ── Upload de arquivos ────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ── Gateway de Pagamento ──────────────────────────────────
# Escolha: 'stripe' | 'asaas' | 'pagarme'
PAYMENT_GATEWAY=stripe

# Stripe (internacional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Asaas (Brasil - PIX, Boleto, Cartão)
# ASAAS_API_KEY=...
# ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# PagarMe (Brasil)
# PAGARME_API_KEY=ak_test_...

# ── E-mail transacional ───────────────────────────────────
# Recomendado: Resend (resend.com) ou SendGrid
EMAIL_PROVIDER=smtp           # 'smtp' | 'resend' | 'sendgrid'
EMAIL_FROM=noreply@custeai.com.br
EMAIL_FROM_NAME=CusteAi

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_app

# Resend
# RESEND_API_KEY=re_...

# SendGrid
# SENDGRID_API_KEY=SG....

# ── Storage de imagens ────────────────────────────────────
# Local: as imagens ficam em ./uploads (padrão desenvolvimento)
# Supabase Storage (recomendado para produção com Supabase):
# STORAGE_PROVIDER=supabase
# SUPABASE_STORAGE_BUCKET=custeai-uploads

# S3 / Cloudflare R2
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_BUCKET=custeai-uploads
# AWS_REGION=sa-east-1
# CDN_URL=https://cdn.custeai.com.br

# ── URLs públicas ─────────────────────────────────────────
APP_URL=https://app.custeai.com.br
LOGO_URL=https://app.custeai.com.br/logo.png
